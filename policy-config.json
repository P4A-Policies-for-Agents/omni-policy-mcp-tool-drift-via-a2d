{
  "a2d": {
    "baseUrl": "http://127.0.0.1:8081",
    "assetId": "my-mcp-server-asset-123",
    "apiKeySecretRef": "a2d-api-key",
    "refreshIntervalSec": 300,
    "pdpTimeoutMs": 250,
    "pinPathPrefix": "/a2d-pin"
  },
  "decision": {
    "source": "cache",
    "hybridSampleRate": 0.1
  },
  "enforce": {
    "exactMatch": true,
    "allowAddedTools": false,
    "allowRemovedTools": true
  },
  "evidence": {
    "reportToA2d": true,
    "logLocally": true
  },
  "mode": "enforce",
  "failOpen": {
    "onSpecUnavailable": false,
    "onPdpUnavailable": true
  }
}
